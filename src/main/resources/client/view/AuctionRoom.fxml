<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>

<BorderPane prefHeight="650.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.AuctionRoomController">
    
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" styleClass="header-bar">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0"/>
            </padding>
            <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="btn-back" text="&lt; Quay lại Trang chủ" />
            <Label styleClass="header-title" text="PHÒNG ĐẤU GIÁ TRỰC TUYẾN" />
            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" styleClass="search-box-container">
                    <TextField prefWidth="250.0" promptText="Tìm kiếm" styleClass="search-input" />
                    <Button mnemonicParsing="false" styleClass="btn-search" text="🔍" />
                </HBox>
            </HBox>
        </HBox>
    </top>

    <center>
        <HBox spacing="30.0" styleClass="main-content">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            
            <VBox prefWidth="400.0" spacing="15.0" styleClass="left-column">
                
                <VBox alignment="CENTER" styleClass="white-box, image-container">
                    <ImageView fx:id="imgProduct" fitHeight="260.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />
                </VBox>
                
                <VBox alignment="CENTER" spacing="10.0">
                    <Label fx:id="lblProductName" styleClass="product-name" text="iPhone 15 Pro Max" />
                    
                    <HBox alignment="CENTER" spacing="10.0">
                        <Label styleClass="label-normal" text="Giá hiện tại:" />
                        <Label fx:id="lblCurrentPrice" styleClass="price-label" text="15.000.000 VNĐ" />
                    </HBox>
                    
                    <HBox alignment="CENTER" spacing="5.0">
                        <Label text="⏱" />
                        <Label fx:id="lblTimer" styleClass="timer-label" text="Thời gian còn lại: 00:01:45" />
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT" prefHeight="4.0" prefWidth="200.0" styleClass="progress-bar-bg" maxWidth="300">
                         <Line endX="100.0" stroke="#e67e22" strokeWidth="4.0" />
                    </HBox>
                </VBox>
                
                <VBox spacing="10.0" styleClass="white-box, details-card">
                    <Label styleClass="card-title" text="Thông tin chi tiết" />
                    <HBox spacing="10.0">
                        <Label styleClass="label-normal" text="Người đăng:" />
                        <Label fx:id="lblSellerName" styleClass="seller-name" text="Van Phu Dung" />
                    </HBox>
                    <Label styleClass="label-normal" text="Mô tả sản phẩm:" />
                    <Label fx:id="lblProductDescription" styleClass="label-normal" text="Thông tin mô tả sẽ được cập nhật sớm..." wrapText="true" />
                    <HBox>
                        <Button fx:id="btnShowDetails" mnemonicParsing="false" onAction="#handleShowDetails" styleClass="btn-secondary" text="Xem đầy đủ chi tiết" />
                    </HBox>
                </VBox>
                
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                <Label styleClass="section-title" text="Lịch sử trả giá" />
                
                <ListView fx:id="listBidHistory" prefHeight="400.0" styleClass="history-list" VBox.vgrow="ALWAYS" />
                
                <HBox spacing="10.0" styleClass="white-box, bid-input-container">
                    <TextField fx:id="txtBidAmount" prefHeight="40.0" promptText="Nhập mức giá bạn muốn trả (VNĐ)..." styleClass="input-field" HBox.hgrow="ALWAYS" />
                    
                    <Button fx:id="btnSubmitBid" defaultButton="true" mnemonicParsing="false" onAction="#handleBidAction" prefHeight="40.0" prefWidth="120.0" styleClass="btn-primary" text="GỬI GIÁ BÁN" />
                </HBox>
            </VBox>
            
        </HBox>
    </center>
</BorderPane>