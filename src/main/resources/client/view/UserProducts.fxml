<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="client.controller.UserProductsController"
            stylesheets="@../css/style.css"
            styleClass="user-products-root"
            prefWidth="1000.0" prefHeight="700.0"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="user-products-topbar">
                <Button mnemonicParsing="false" onAction="#handleBackToProductList"
                        styleClass="user-back-button"
                        text="&lt; Trang sản phẩm" />
                <VBox spacing="2.0">
                    <Label styleClass="user-products-title" text="Quản lý sản phẩm của tôi" />
                    <Label styleClass="user-products-subtitle" text="Theo dõi, chỉnh sửa và xóa các phiên bạn đã đăng" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleGoToAddProduct"
                        styleClass="user-primary-button"
                        text="➕ Đăng sản phẩm mới" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="18.0" styleClass="user-products-content">
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="user-summary-card">
                <VBox spacing="4.0">
                    <Label text="Tài khoản" styleClass="user-summary-label" />
                    <Label fx:id="lblCurrentUser" text="Loading..." styleClass="user-summary-value" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="4.0">
                    <Label text="Số sản phẩm đã đăng" styleClass="user-summary-label" />
                    <Label fx:id="lblTotalProducts" text="0" styleClass="user-summary-count" />
                </VBox>
            </HBox>

            <TableView fx:id="tableProducts" VBox.vgrow="ALWAYS" styleClass="user-products-table">
                <columns>
                    <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="260" />
                    <TableColumn fx:id="colCategory" text="Danh mục" prefWidth="130" />
                    <TableColumn fx:id="colPrice" text="Giá hiện tại" prefWidth="140" />
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="140" />
                    <TableColumn fx:id="colEndTime" text="Thời gian kết thúc" prefWidth="220" />
                    <TableColumn fx:id="colAction" text="Thao tác" prefWidth="180" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
