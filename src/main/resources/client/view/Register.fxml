<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="client.controller.RegisterController" 
      alignment="CENTER" 
      spacing="15.0" 
      xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-padding: 20px;">
      <Label text="ĐĂNG KÝ TÀI KHOẢN MỚI" 
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtFullName" 
               promptText="Nhập họ và tên..." 
               maxWidth="250.0"/>

    <TextField fx:id="txtUsername" 
               promptText="Nhập tên đăng nhập..." 
               maxWidth="250.0"/>

    <PasswordField fx:id="txtPassword" 
                   promptText="Nhập mật khẩu..." 
                   maxWidth="250.0"/>

    <PasswordField fx:id="txtConfirmPassword" 
                   promptText="Xác nhận lại mật khẩu..." 
                   maxWidth="250.0"/>

    <ComboBox fx:id="cbRole" 
              promptText="Chọn vai trò của bạn" 
              maxWidth="250.0"/>

    <Button fx:id="btnRegister" 
            text="Đăng ký ngay" 
            onAction="#handleRegisterAction" 
            prefWidth="150.0"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </VBox>