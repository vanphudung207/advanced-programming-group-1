<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.CustomMenuItem?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane fx:controller="client.controller.ProductListController" 
            stylesheets="@../css/style.css"
            prefWidth="900.0" prefHeight="600.0"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox>
            <VBox spacing="10.0" style="-fx-background-color: #0b5ed7; -fx-padding: 15px;">
                
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label text="⚖ LOGO" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="AUCTIONET GROUP 1" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    
                    <Region HBox.hgrow="ALWAYS" />

                    <Button text="➕ Đăng sản phẩm" onAction="#handleGoToAddProduct" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 15px; -fx-background-radius: 5px;"/>
                    
                    <MenuButton text="Tài khoản" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 5px; -fx-text-fill: white; -fx-cursor: hand;">
                        <items>
                            <CustomMenuItem hideOnClick="false">
                                <content>
                                    <Button fx:id="btnInfo" text="Thông tin" onAction="#handleShowInfo" style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                </content>
                            </CustomMenuItem>
                            <MenuItem text="Đăng xuất" onAction="#handleLogoutAction"/>
                        </items>
                    </MenuButton>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblDateTime" text="00:00 AM | 01 Jan, 2026" style="-fx-text-fill: #e0e0e0; -fx-font-size: 14px;"/>
                </HBox>
            </VBox>

            <HBox style="-fx-background-color: #f8f9fa; -fx-border-color: #333; -fx-border-width: 2px 0 2px 0;">
                
                <Button text="Thể thao" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                        style="-fx-text-fill: #333; -fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 0 1px 0 0; -fx-padding: 15px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                
                <Button text="Gia dụng" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                        style="-fx-text-fill: #333; -fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 0 1px 0 0; -fx-padding: 15px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                
                <Button text="Điện tử" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                        style="-fx-text-fill: #333; -fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 0 1px 0 0; -fx-padding: 15px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                
                <Button text="Sách" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                        style="-fx-text-fill: #333; -fx-background-color: transparent; -fx-border-color: #333; -fx-border-width: 0 1px 0 0; -fx-padding: 15px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                
                <Button text="Giải trí" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                        style="-fx-text-fill: #333; -fx-background-color: transparent; -fx-padding: 15px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </top><top>
      <VBox>
         <children>
            
            <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #e64a19; -fx-padding: 8px 20px;">
               <children>
                  <Label style="-fx-text-fill: white; -fx-font-size: 13px;" text="Hà Nội, Việt Nam" />
                  
                  <Label fx:id="lblDateTime" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Đang tải thời gian..." />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button mnemonicParsing="false" onAction="#handleGoToAddProduct" style="-fx-background-color: white; -fx-text-fill: #e64a19; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 5px 15px; -fx-background-radius: 5px;" text="➕ Đăng sản phẩm" />
                  
                  <MenuButton mnemonicParsing="false" style="-fx-background-color: transparent; -fx-border-color: white; -fx-border-radius: 5px; -fx-text-fill: white; -fx-cursor: hand;" text="Tài khoản">
                     <items>
                        <CustomMenuItem hideOnClick="false">
                           <content>
                              <Button fx:id="btnInfo" onAction="#handleShowInfo" style="-fx-background-color: transparent; -fx-text-fill: #333; -fx-font-weight: bold; -fx-cursor: hand;" text="Thông tin" />
                           </content>
                        </CustomMenuItem>
                        <MenuItem mnemonicParsing="false" onAction="#handleLogoutAction" text="Đăng xuất" />
                     </items>
                  </MenuButton>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="30.0" style="-fx-background-color: white; -fx-padding: 15px 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <children>
                  
                  <VBox alignment="CENTER">
                     <children>
                        <Label style="-fx-text-fill: #c0392b; -fx-font-size: 36px; -fx-font-weight: bold;" text="⚖ NALAF" />
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" text="Lựa chọn cho thành công" />
                     </children>
                  </VBox>
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <VBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5D4037;" text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN - GROUP 1" />
                        <Label style="-fx-font-size: 22px; -fx-text-fill: #5D4037;" text="TỔ CHỨC THỰC HIỆN ĐẤU GIÁ CHUYÊN NGHIỆP &amp; MINH BẠCH" />
                     </children>
                  </VBox>
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
               </children>
            </HBox>
            
         </children>
      </VBox>
   </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane fx:id="productContainer" hgap="20.0" vgap="20.0" style="-fx-padding: 20px; -fx-background-color: #ecf0f1;">
                </FlowPane>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #e0e0e0; -fx-padding: 15px;">
            <Label text="About Us" style="-fx-cursor: hand;"/>
            <Label text="Support" style="-fx-cursor: hand;"/>
            <Label text="Contact" style="-fx-cursor: hand;"/>
            <Label text="Terms &amp; Conditions" style="-fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>